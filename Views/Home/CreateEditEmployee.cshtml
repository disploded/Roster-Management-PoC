@{
    ViewData["Title"] = "Create / Edit";
}

@model RosterApp.Models.Employee

<div class="text-center">
    <h1 class="display-4">Create or edit employee</h1>
</div>

<form asp-action="CreateEditEmployeeForm" asp-controller="Home">
    <input hidden class="form-control" type="number" placeholder="0" asp-for="Id"/>
    <label class="mt-4">Name</label>
    <input class="form-control" type="text" placeholder="Name" asp-for="Name" />
    <label class="mt-4">Job Description</label>
    <input class="form-control" type="text" placeholder="Description" asp-for="Description" />

    <button class="btn btn-primary mt-4" type="submit">Ok</button>
</form>