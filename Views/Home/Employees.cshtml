@{
    ViewData["Title"] = "Employees";
}

@model List<Employee>

<div class="text-center">
    <h1 class="display-4">Employees Page</h1>
    <p>This is where the employees will be listed. <br /> You can add or edit them, as well</p>

    <br />
    <table class="table">
        <thead>
            <tr>
                <th>
                    Name
                </th>
                <th>
                    Job Description
                </th>
            </tr>
        </thead>
        <tbody>
            @{
                foreach (var employee in Model) {
                    <tr>
                        <td>
                            @employee.Name
                        </td>
                        <td>
                            @employee.Description
                        </td>
                        <td>
                        <a asp-action="CreateEditEmployee" asp-route-id="@employee.Id">Edit</a>
                        <a asp-action="DeleteEmployee" asp-route-id="@employee.Id">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <a asp-controller="Home" asp-action="CreateEditEmployee" class="btn btn-primary mt-xxl-5">Create new</a>
</div>
